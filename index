  thesis:"A pergunta não é se a tecnologia influencia eleições. É que cada tecnologia redefine o que conta como eleitor, como verdade e como voto."
};

/* ================= ESTADO / DOM ================= */
const store=document.getElementById('svg-store');
const svgOf=k=>store.querySelector('[data-k="'+k+'"]').innerHTML;
const plate=document.getElementById('plate'), chip=document.getElementById('chip'),
      spotsEl=document.getElementById('spots'), trail=document.getElementById('trail'),
      counter=document.getElementById('counter'), stage=document.getElementById('stage'),
      pop=document.getElementById('pop'), scrim=document.getElementById('scrim'), hint=document.getElementById('hint');
let idx=0, pIdx=-1;                 // pIdx: ponto atual (0 = contexto)
const TOTAL=SCENES.length+1;        // +fio
const isFio=i=>i===SCENES.length;

function pointsOf(i){
  if(isFio(i)) return [{kind:'fio'}];
  const s=SCENES[i];
  return [{kind:'ctx'}, ...s.spots.map((sp,si)=>({kind:'spot',si:si,sp:sp}))];
}

[...SCENES.map(s=>({yr:s.yr,nm:s.nm})),{yr:"—",nm:"O fio"}].forEach((s,i)=>{
  const b=document.createElement('button');
  b.className='stop'; b.innerHTML='<span class="dot"></span><span class="yr">'+s.yr+'</span><span class="nm">'+s.nm+'</span>';
  b.addEventListener('click',()=>go(i)); trail.appendChild(b);
});

function go(i){
  if(i<0||i>=TOTAL) return;
  idx=i; closePop();
  stage.classList.add('fading');
  setTimeout(renderStage,240);
  updateChrome();
  history.replaceState(null,'','#'+(isFio(i)?'fio':SCENES[i].k));
}

function renderStage(){
  spotsEl.innerHTML=''; chip.innerHTML='';
  const key=isFio(idx)?'arena':SCENES[idx].k;
  plate.className='plate'; plate.innerHTML=svgOf(key);

  if(isFio(idx)){
    chip.innerHTML='<div class="ey">Síntese</div><h2>'+FIO.title+'</h2>';
    requestAnimationFrame(()=>{plate.classList.add('on');stage.classList.remove('fading');});
    openPoint(0);
    return;
  }
  const s=SCENES[idx];
  chip.innerHTML='<div class="ey">Cap. '+String(idx+1).padStart(2,'0')+' · '+s.yr+'</div>'+
    '<h2>'+s.title+'</h2>'+
    '<button class="ctx" id="chipCtx"><i>i</i> Contexto</button>';
  chip.querySelector('#chipCtx').addEventListener('click',()=>openPoint(0));
  s.spots.forEach((sp,si)=>{
    const el=document.createElement('button');
    el.className='spot'; el.style.left=(sp.x/1600*100)+'%'; el.style.top=(sp.y/900*100)+'%';
    el.setAttribute('aria-label',sp.t);
    el.innerHTML='<i></i><span class="num">'+(si+1)+'</span>';
    el.addEventListener('click',()=>openPoint(si+1));
    spotsEl.appendChild(el);
  });
  requestAnimationFrame(()=>{plate.classList.add('on');stage.classList.remove('fading');});
  openPoint(0);
}

function updateChrome(){
  [...trail.children].forEach((b,i)=>{b.classList.toggle('active',i===idx);b.classList.toggle('done',i<idx);});
  counter.innerHTML='<b>'+String(idx+1).padStart(2,'0')+'</b> / '+String(TOTAL).padStart(2,'0');
  document.getElementById('prev').disabled=idx===0;
  document.getElementById('next').disabled=idx===TOTAL-1;
  const a=trail.children[idx]; if(a) a.scrollIntoView({inline:'center',block:'nearest',behavior:'smooth'});
}

/* ---------- popup ---------- */
const popKick=document.getElementById('popKick'), popTitle=document.getElementById('popTitle'),
      popBody=document.getElementById('popBody'), popCount=document.getElementById('popCount'),
      popPrev=document.getElementById('popPrev'), popNext=document.getElementById('popNext');

function openPoint(pi){
  const pts=pointsOf(idx); if(pi<0||pi>=pts.length) return;
  pIdx=pi; const pt=pts[pi];
  let anchor={x:800,y:470,center:true};

  if(pt.kind==='fio'){
    popKick.textContent='Síntese · O fio';
    popTitle.textContent=FIO.title;
    popBody.innerHTML='<p class="lead">'+FIO.paras[0]+'</p><p>'+FIO.paras[1]+'</p><p>'+FIO.paras[2]+'</p>'+
      '<div class="pop-thesis">'+FIO.thesis+'</div>';
  }else if(pt.kind==='ctx'){
    const s=SCENES[idx];
    popKick.textContent='Contexto · '+s.yr;
    popTitle.textContent=s.title;
    popBody.innerHTML=s.context.map((p,i)=>'<p'+(i===0?' class="lead"':'')+'>'+p+'</p>').join('');
    anchor={x:430,y:250};
  }else{
    const sp=pt.sp;
    popKick.textContent='Ponto '+(pt.si+1)+' · '+SCENES[idx].yr;
    popTitle.textContent=sp.t;
    popBody.innerHTML=sp.b.map((p,i)=>'<p'+(i===0?' class="lead"':'')+'>'+p+'</p>').join('');
    anchor={x:sp.x,y:sp.y};
  }
  popBody.scrollTop=0;

  const last=pts.length-1;
  popCount.textContent=isFio(idx)?'':(pi+1)+' / '+pts.length;
  popPrev.disabled=(pi===0 && idx===0);
  if(pi===last){
    if(idx===TOTAL-1){ popNext.innerHTML='Recomeçar <svg viewBox="0 0 24 24"><path d="M4 12a8 8 0 1 0 2-5"/><path d="M6 3v4h4"/></svg>'; }
    else { popNext.innerHTML='Próximo capítulo <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>'; }
  }else{
    popNext.innerHTML='Próximo <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg>';
  }

  [...spotsEl.children].forEach((e,i)=>e.classList.toggle('active',pt.kind==='spot'&&i===pt.si));

  pop.classList.add('open'); scrim.classList.add('show');
  positionPop(anchor);
  hideHint();
}

function positionPop(anchor){
  if(window.innerWidth<=720) return;
  const W=stage.clientWidth, H=stage.clientHeight;
  const w=pop.offsetWidth, h=pop.offsetHeight;
  let left,top;
  if(anchor.center){ left=(W-w)/2; top=(H-h)/2; }
  else{
    const px=anchor.x/1600*W, py=anchor.y/900*H;
    left=px+28; if(left+w>W-12) left=px-w-28; if(left<12) left=12;
    top=py-h/2;
  }
  top=Math.max(12,Math.min(top,H-h-12));
  left=Math.max(12,Math.min(left,W-w-12));
  pop.style.left=left+'px'; pop.style.top=top+'px';
}
function stepPop(dir){
  const pts=pointsOf(idx);
  if(dir>0 && pIdx===pts.length-1){
    if(idx===TOTAL-1){ closePop(); go(0); } else { go(idx+1); }
    return;
  }
  if(dir<0 && pIdx===0){ if(idx>0){ go(idx-1); } return; }
  openPoint(pIdx+dir);
}
function closePop(){ pop.classList.remove('open'); scrim.classList.remove('show'); [...spotsEl.children].forEach(e=>e.classList.remove('active')); pIdx=-1; }

document.getElementById('popX').addEventListener('click',closePop);
popPrev.addEventListener('click',()=>stepPop(-1));
popNext.addEventListener('click',()=>stepPop(1));
scrim.addEventListener('click',closePop);
document.getElementById('ctxBtn').addEventListener('click',()=>openPoint(0));

document.getElementById('prev').addEventListener('click',()=>go(idx-1));
document.getElementById('next').addEventListener('click',()=>go(idx+1));
document.getElementById('homeBtn').addEventListener('click',showLanding);
document.addEventListener('keydown',e=>{
  if(!document.getElementById('landing').classList.contains('gone')){ if(e.key==='Enter') enterApp(); return; }
  if(e.key==='Escape'){ closePop(); return; }
  if(pop.classList.contains('open')){
    if(e.key==='ArrowRight') stepPop(1);
    else if(e.key==='ArrowLeft') stepPop(-1);
  }else{
    if(e.key==='ArrowRight') go(idx+1);
    else if(e.key==='ArrowLeft') go(idx-1);
  }
});
window.addEventListener('resize',()=>{
  if(pop.classList.contains('open')){
    const pts=pointsOf(idx), pt=pts[pIdx]; let a={x:800,y:470,center:true};
    if(pt&&pt.kind==='spot') a={x:pt.sp.x,y:pt.sp.y}; else if(pt&&pt.kind==='ctx') a={x:430,y:250};
    positionPop(a);
  }
});

let hintOff=false; function hideHint(){ if(!hintOff){hint.classList.add('hide');hintOff=true;} }

const landing=document.getElementById('landing'), appEl=document.getElementById('app');
document.getElementById('enter').addEventListener('click',enterApp);
function enterApp(){
  landing.classList.add('gone'); appEl.setAttribute('aria-hidden','false');
  const h=(location.hash||'').replace('#','');
  let start=0;
  if(h==='fio') start=SCENES.length;
  else{ const j=SCENES.findIndex(s=>s.k===h); if(j>=0) start=j; }
  idx=start; renderStage(); updateChrome();
}
function showLanding(){ closePop(); landing.classList.remove('gone'); appEl.setAttribute('aria-hidden','true'); }
</script>
